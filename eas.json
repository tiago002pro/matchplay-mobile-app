{
  "cli": {
    "version": ">= 9.1.0"
  },
  "build": {
    "development": {
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "EXPO_PUBLIC_API_URL": "http://192.168.18.10:8080/api/matchplay",
        "EXPO_PUBLIC_WEBSOCKET_URL": "ws://192.168.18.10:8080/api/matchplay/ws"
      },
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_API_URL": "https://api.matchplay.cloud/api/matchplay",
        "EXPO_PUBLIC_WEBSOCKET_URL": "wss://api.matchplay.cloud/api/matchplay/ws"
      },
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    }
  }
}
